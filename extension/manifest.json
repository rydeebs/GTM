{
  "manifest_version": 3,
  "name": "GTMhub Flow Importer",
  "version": "1.0.0",
  "description": "Import automation flows from Zapier and Clay into GTMhub",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://zapier.com/*",
    "https://app.clay.com/*",
    "https://api.gtmhub.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://zapier.com/editor/*",
        "https://zapier.com/app/editor/*"
      ],
      "js": ["content_scripts/zapier.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.clay.com/*"
      ],
      "js": ["content_scripts/clay.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
